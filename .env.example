# API Token for internal service communication
# Generate a secure token, e.g., with: openssl rand -hex 32
API_BEARER_TOKEN=your_secure_random_token_here

# Allowed host for Host header validation
# Example: unefficacious-cozily-karlee.ngrok-free.dev or localhost
ALLOWED_HOST=localhost

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Ngrok Auth Token (Optional if running ngrok manually)
NGROK_AUTHTOKEN=your_ngrok_auth_token_here
